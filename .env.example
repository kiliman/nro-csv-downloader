# Copy to .env and fill in your values:  cp .env.example .env
# Then run:  set -a; source .env; set +a; ./download-nro-csv.sh
# (the script reads these from the environment)

# --- required ---------------------------------------------------------------
NRO_EMAIL=you@example.com        # nro.group login email
NRO_PASSWORD=your-password       # nro.group login password

# --- optional ---------------------------------------------------------------
# NRO_PROJECT="Quarterly"        # match a project by name substring; defaults to the first project
# OUTPUT_DIR=./downloads         # where CSVs are saved (can also be passed as $1); defaults to ./downloads
# FORCE=1                        # re-download even if we already have the latest file
